// ── SAVE / LOAD ─────────────────────────────────────────────────
function saveTrip(){
  const cities=getCities(),budget=document.getElementById('budget').value,dur=document.getElementById('duration').value;
  if(!cities.length||!budget||!dur)return alert('Please generate a plan first.');
  let saved=JSON.parse(localStorage.getItem('vdark2')||'[]');
  saved.unshift({id:Date.now(),cities,budget:+budget,dur:+dur,accom:document.getElementById('accom').value,date:new Date().toLocaleDateString('en-IN')});
  if(saved.length>6)saved=saved.slice(0,6);
  localStorage.setItem('vdark2',JSON.stringify(saved));
  renderSaved();alert('Trip saved.');
}

function renderSaved(){
  const saved=JSON.parse(localStorage.getItem('vdark2')||'[]');
  const el=document.getElementById('saved-list');
  if(!saved.length){el.innerHTML='<div style="font-size:0.7rem;color:var(--mist);font-style:italic">No saved trips yet.</div>';return;}
  el.innerHTML=saved.map(t=>`
    <div class="saved-item">
      <div>
        <div class="s-name">${t.cities.slice(0,3).join(' · ')}${t.cities.length>3?'…':''}</div>
        <div class="s-meta">₹${t.budget.toLocaleString('en-IN')} · ${t.dur} days · ${t.date}</div>
      </div>
      <div class="s-btns">
        <button class="btn-xs" onclick="loadTrip(${t.id})">Load</button>
        <button class="btn-xs del" onclick="delTrip(${t.id})">✕</button>
      </div>
    </div>`).join('');
}

function loadTrip(id){
  const saved=JSON.parse(localStorage.getItem('vdark2')||'[]');
  const t=saved.find(x=>x.id===id);if(!t)return;
  const list=document.getElementById('clist');list.innerHTML='';_n=0;
  t.cities.forEach((c,i)=>{
    _n++;
    const row=document.createElement('div');row.className='c-row';
    row.innerHTML=`<span class="c-idx">${String(i+1).padStart(2,'0')}</span><input type="text" value="${c}"/><button class="btn-rm" onclick="rmCity(this)">×</button>`;
    list.appendChild(row);
  });
  document.getElementById('budget').value=t.budget;
  document.getElementById('duration').value=t.dur;
  document.getElementById('accom').value=t.accom;
  generate();
}

function delTrip(id){
  let s=JSON.parse(localStorage.getItem('vdark2')||'[]');
  s=s.filter(x=>x.id!==id);
  localStorage.setItem('vdark2',JSON.stringify(s));
  renderSaved();
}

renderSaved();
</script>
</body>
</html>
