const TIMES=["07:30","09:00","12:00","14:30","17:00","19:30","21:00"];
let _cities=[];

// ══════════════════════════════════════════════════════════════
// UI SETUP
// ══════════════════════════════════════════════════════════════
document.querySelectorAll('.pill').forEach(p=>{
  p.addEventListener('click',()=>{
    document.querySelectorAll('#cpills .pill').forEach(x=>x.classList.remove('on'));
    p.classList.add('on');
  });
});

let _n=2;

function addCity(){
  _n++;
  const list=document.getElementById('clist');
  const row=document.createElement('div');
  row.className='c-row';
  row.innerHTML=`<span class="c-idx">${String(_n).padStart(2,'0')}</span><input type="text" placeholder="City name"/><button class="btn-rm" onclick="rmCity(this)">×</button>`;
  list.appendChild(row);
  row.querySelector('input').focus();
  reIdx();
}

function rmCity(btn){
  if(document.querySelectorAll('#clist .c-row').length<=2)return alert('Minimum 2 cities required.');
  btn.closest('.c-row').remove();reIdx();
}

function reIdx(){
  document.querySelectorAll('#clist .c-row').forEach((r,i)=>{
    r.querySelector('.c-idx').textContent=String(i+1).padStart(2,'0');
  });
}

function getCities(){
  return Array.from(document.querySelectorAll('#clist .c-row input')).map(i=>i.value.trim()).filter(Boolean);
}

function norm(c){return Object.keys(CITY).find(k=>k.toLowerCase()===c.toLowerCase())||c;}
function getCuisine(){const el=document.querySelector('#cpills .pill.on');return el?el.dataset.v:'Any';}

// ══════════════════════════════════════════════════════════════
// GENERATE
// ══════════════════════════════════════════════════════════════
function generate(){
  const raw=getCities();
  const budget=parseFloat(document.getElementById('budget').value)||0;
  const dur=parseInt(document.getElementById('duration').value)||0;
  const accom=document.getElementById('accom').value;
  if(raw.length<2)return alert('Please enter at least 2 cities.');
  if(budget<1000)return alert('Please enter a valid budget (min ₹1,000).');
  if(dur<1)return alert('Please enter a valid duration.');

  const cities=raw.map(norm);
  _cities=cities;
  const dpC=distDays(dur,cities.length);
  const nCost=ACCOM[accom];
  const tAccom=dur*nCost;
  const tTravel=Math.round(budget*0.22);
  const rem=budget-tAccom-tTravel;
  const food=Math.max(0,Math.round(rem*0.58));
  const act=Math.max(0,rem-food);
  const perC=cities.map((_,i)=>({
    accom:dpC[i]*nCost,
    food:Math.round((food/dur)*dpC[i]),
    act:Math.round((act/dur)*dpC[i]),
    travel:Math.round(tTravel/Math.max(cities.length-1,1)),
  }));

  renderStats(cities,budget,dur);
  renderRoute(cities);
  renderItin(cities,dpC);
  renderBudget(budget,tAccom,tTravel,food,act,cities,perC,dpC);
  renderRests(cities);
  renderHotels(cities,dpC,accom);

  const out=document.getElementById('output');
  out.classList.add('show');
  setTimeout(()=>out.scrollIntoView({behavior:'smooth',block:'start'}),80);
}

function distDays(total,count){
  const base=Math.floor(total/count),rem=total%count;
  return Array.from({length:count},(_,i)=>base+(i<rem?1:0));
}

// ══════════════════════════════════════════════════════════════
// RENDER FUNCTIONS
// ══════════════════════════════════════════════════════════════
function renderStats(cities,budget,dur){
  document.getElementById('stats').innerHTML=[
    {v:cities.length,l:'Cities'},{v:dur,l:'Days'},
    {v:'₹'+Math.round(budget/1000)+'K',l:'Total Budget'},
    {v:'₹'+Math.round(budget/dur).toLocaleString('en-IN'),l:'Per Day'},
  ].map(s=>`<div class="stat"><div class="stat-val">${s.v}</div><div class="stat-lbl">${s.l}</div></div>`).join('');
}

function renderRoute(cities){
  document.getElementById('rtrack').innerHTML=cities.map((c,i)=>{
    const cls=i===0?'start':i===cities.length-1?'end':'';
    const line=i<cities.length-1?`<div class="r-line"></div>`:'';
    return `<div class="r-stop"><div class="r-node"><div class="r-ring ${cls}">${String.fromCharCode(65+i)}</div><div class="r-name">${c}</div></div>${line}</div>`;
  }).join('');
}

function renderItin(cities,dpC){
  let html='',day=1;
  cities.forEach((city,ci)=>{
    const d=CITY[city]||{h:[],t:'Local transport'};
    const hi=[...d.h];
    for(let dd=0;dd<dpC[ci];dd++){
      const slice=hi.splice(0,2);
      const acts=buildActs(city,slice,dd,dpC[ci],d.t);
      const isOpen=dd===0&&ci===0;
      html+=`<div class="day-card${isOpen?' open':''}">
        <div class="day-head" onclick="toggleDay(this)">
          <div class="dhl">
            <span class="d-badge">Day ${String(day).padStart(2,'0')}</span>
            <span class="d-title">${dayTitle(dd,dpC[ci],city)}</span>
          </div>
          <div style="display:flex;align-items:center;gap:0.7rem">
            <span class="d-city">${city}</span>
            <span class="d-chev">›</span>
          </div>
        </div>
        <div class="day-body${isOpen?' open':''}">
          <ul class="sched">${acts.map((a,ai)=>`<li class="srow"><span class="stime">${TIMES[ai]||'—'}</span><span class="stext">${a}</span></li>`).join('')}</ul>
        </div>
      </div>`;
      day++;
    }
    if(ci<cities.length-1)html+=`<div class="transit"><span>✦ Transfer — ${city} → ${cities[ci+1]}</span></div>`;
  });
  document.getElementById('pane-itin').innerHTML=html;
}

function dayTitle(idx,total,city){
  if(total===1)return`Exploring ${city}`;
  if(idx===0)return`Arrival — ${city}`;
  if(idx===total-1)return`Final Day in ${city}`;
  return`${city} — Day ${idx+1}`;
}

function buildActs(city,slice,dayIdx,totalDays,transport){
  return[
    dayIdx===0?`Arrive in <strong>${city}</strong>. Check in and settle.`:`Morning — local breakfast and orientation.`,
    slice[0]?`Visit <strong>${slice[0]}</strong>.`:`Explore local markets at a leisurely pace.`,
    `Lunch — sample regional cuisine. <span class="ssub">See Restaurants tab for curated suggestions.</span>`,
    slice[1]?`Afternoon at <strong>${slice[1]}</strong>.`:`Free time for shopping or relaxation.`,
    `Evening movement. <span class="ssub">${transport}</span>`,
    dayIdx===totalDays-1&&totalDays>1?`Pack and prepare for departure. Farewell dinner.`:`Dinner and rest for tomorrow's journey.`,
  ];
}

function toggleDay(head){
  const card=head.closest('.day-card');
  card.classList.toggle('open');
  head.nextElementSibling.classList.toggle('open');
}

function renderBudget(budget,accom,travel,food,act,cities,perC,dpC){
  const bars=[
    {l:'Accommodation',a:accom,col:'#D4A847'},{l:'Travel & Transport',a:travel,col:'#2EC4B6'},
    {l:'Food & Dining',a:food,col:'#A87ED4'},{l:'Activities',a:act,col:'#E07070'},
  ];
  const cityCards=cities.map((c,i)=>`
    <div class="city-bcard">
      <div class="city-bname">${c}</div>
      <div style="font-size:0.62rem;color:var(--mist);margin-bottom:0.45rem">${dpC[i]} day${dpC[i]>1?'s':''}</div>
      ${[['Stay',perC[i].accom],['Food',perC[i].food],['Activity',perC[i].act],['Transit',perC[i].travel]].map(r=>`<div class="brow2"><span>${r[0]}</span><span class="v">₹${r[1].toLocaleString('en-IN')}</span></div>`).join('')}
      <div style="height:1px;background:var(--edge);margin:0.5rem 0"></div>
      <div class="brow2" style="color:var(--silver)"><span>Total</span><span class="v" style="color:var(--amber)">₹${(perC[i].accom+perC[i].food+perC[i].act+perC[i].travel).toLocaleString('en-IN')}</span></div>
    </div>`).join('');
  document.getElementById('pane-budget').innerHTML=`
    <div class="bud-grid">
      <div class="bud-stat"><div class="bud-val">₹${budget.toLocaleString('en-IN')}</div><div class="bud-lbl">Total Budget</div></div>
      <div class="bud-stat"><div class="bud-val">₹${Math.round(budget/dpC.reduce((a,b)=>a+b,0)).toLocaleString('en-IN')}</div><div class="bud-lbl">Daily Average</div></div>
    </div>
    <div class="bars-wrap">${bars.map(b=>`<div class="brow"><div class="brow-top"><span class="brow-name">${b.l}</span><span class="brow-amt">₹${b.a.toLocaleString('en-IN')}</span></div><div class="btrack"><div class="bfill" style="width:${Math.round(b.a/budget*100)}%;background:${b.col}"></div></div></div>`).join('')}</div>
    <div class="s-eyebrow" style="margin-bottom:1rem">Per-City Allocation</div>
    <div class="city-grid">${cityCards}</div>
    <div class="bud-tip">Recommendation — Reserve ₹${Math.round(budget*0.05).toLocaleString('en-IN')} (5% of budget) as an emergency contingency throughout your journey.</div>`;
}

function renderRests(cities,filterC){
  const cuisine=filterC||getCuisine();
  const fpills=['Any','North Indian','South Indian','Seafood','Continental','Mughlai','Street Food']
    .map(c=>`<button class="pill${cuisine===c?' on':''}" onclick="renderRests(_cities,'${c}')">${c}</button>`).join('');
  let sections='';
  cities.forEach((city,ci)=>{
    const all=RESTS[city]||[{n:`${city} Restaurant`,c:'Multi-Cuisine',r:4.0,p:'₹₹',l:'City Centre'}];
    const rests=cuisine==='Any'?all:all.filter(r=>r.c.toLowerCase().includes(cuisine.toLowerCase()));
    const next=cities[ci+1];
    sections+=`<div class="rsection">
      <div class="rsec-title"><div class="rsec-dot"></div>${next?`En-route: ${city} → ${next}`:`${city} (Final Destination)`}</div>
      ${rests.length?`<div class="rest-grid">${rests.map((r,ri)=>`
        <div class="rcard">
          <div class="rcard-accent" style="background:${ACCENTS[ri%ACCENTS.length]}"></div>
          <div class="rname">${r.n}</div>
          <div class="rtags"><span class="rtag">${r.c}</span><span class="rtag">${r.l}</span></div>
          <div class="rfoot"><span class="rrating">★ ${r.r}</span><span class="rprice">${r.p}</span></div>
        </div>`).join('')}</div>`:`<div class="no-rest">No ${cuisine} restaurants found. Try "Any".</div>`}
    </div>`;
  });
  document.getElementById('pane-restaurants').innerHTML=`<div class="rf-bar"><span class="rf-lbl">Filter</span>${fpills}</div>${sections}`;
}

// ── HOTELS ──────────────────────────────────────────────────────
function renderHotels(cities,dpC,accomTier,filterTier){
  const tier=filterTier||'all';
  const tierPills=[
    {v:'all',l:'All Tiers'},
    {v:'budget',l:'Budget'},
    {v:'mid',l:'Mid-Range'},
    {v:'luxury',l:'Luxury'},
  ].map(t=>`<button class="pill${tier===t.v?' on':''}" onclick="renderHotels(_cities,_dpC,'${accomTier||document.getElementById('accom').value}','${t.v}')">${t.l}</button>`).join('');

  // store dpC globally for filter reuse
  window._dpC=dpC;

  let sections='';
  cities.forEach((city,ci)=>{
    const all=HOTELS[city]||[{n:`${city} Hotel`,s:3,tier:'mid',r:4.0,pn:2000,loc:'City Centre',am:['Free WiFi','AC'],badge:null}];
    const list=tier==='all'?all:all.filter(h=>h.tier===tier);

    // Sort: recommended first, then by rating desc
    list.sort((a,b)=>{
      if(a.badge&&!b.badge)return -1;
      if(!a.badge&&b.badge)return 1;
      return b.r-a.r;
    });

    const nights=dpC[ci];
    sections+=`<div class="hcity-section">
      <div class="hcity-hd">
        <div class="hcity-label"><div class="hcity-dot"></div>${city}</div>
        <div class="hnight-badge">${nights} night${nights>1?'s':''}</div>
      </div>
      ${list.length?`<div class="hotel-grid">${list.map(h=>{
        const stars='★'.repeat(h.s)+'☆'.repeat(Math.max(0,5-h.s));
        const rFill=Math.round((h.r/5)*100);
        const stripCol=TIER_COL[h.tier]||'#D4A847';
        const totalCost=(h.pn*nights).toLocaleString('en-IN');
        return `<div class="hcard">
          <div class="hcard-stripe" style="background:${stripCol}"></div>
          <div class="hcard-body">
            ${h.badge?`<span class="hcard-badge ${h.badge}">${h.badge==='pop'?'Popular':'Recommended'}</span>`:''}
            <div class="hcard-stars">${stars}</div>
            <div class="hcard-name">${h.n}</div>
            <div class="hcard-loc">${h.loc}</div>
            <div class="hcard-amenities">${h.am.map(a=>`<span class="hcard-amenity">${a}</span>`).join('')}</div>
          </div>
          <div class="hcard-foot">
            <div class="hcard-price">
              <div class="hcard-price-val">₹${h.pn.toLocaleString('en-IN')}<span>/night</span></div>
              <div class="hcard-price-lbl">₹${totalCost} for ${nights} night${nights>1?'s':''}</div>
            </div>
            <div class="hcard-rating-wrap">
              <div class="hcard-r-num">${h.r}/5</div>
              <div class="hcard-r-bar"><div class="hcard-r-fill" style="width:${rFill}%;background:${stripCol}"></div></div>
            </div>
          </div>
        </div>`;
      }).join('')}</div>`:`<div class="no-hotel">No ${tier} tier hotels found for ${city}. Try "All Tiers".</div>`}
    </div>`;
  });

  document.getElementById('pane-hotels').innerHTML=`
    <div class="hf-bar">
      <span class="hf-lbl">Tier</span>
      ${tierPills}
    </div>
    ${sections}`;
}

