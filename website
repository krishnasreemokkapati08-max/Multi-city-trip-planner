<div class="layout">

  <!-- FORM PANEL -->
  <aside>
    <div class="form-panel">
      <div class="form-panel-head">
        <div class="panel-icon-wrap">✦</div>
        <div class="panel-title">Configure Trip</div>
      </div>
      <div class="form-body">

        <div class="field">
          <label class="flabel">Destinations</label>
          <div class="cities-wrap" id="clist">
            <div class="c-row"><span class="c-idx">01</span><input type="text" placeholder="e.g. Mumbai" value="Mumbai"/><button class="btn-rm" onclick="rmCity(this)">×</button></div>
            <div class="c-row"><span class="c-idx">02</span><input type="text" placeholder="e.g. Goa" value="Goa"/><button class="btn-rm" onclick="rmCity(this)">×</button></div>
          </div>
          <button class="btn-add" onclick="addCity()">+ Add destination</button>
        </div>

        <div class="hr"></div>

        <div class="field">
          <label class="flabel">Total Budget (₹)</label>
          <input type="number" id="budget" value="50000" min="1000"/>
        </div>

        <div class="field">
          <label class="flabel">Duration (days)</label>
          <input type="number" id="duration" value="7" min="1" max="60"/>
        </div>

        <div class="field">
          <label class="flabel">Accommodation Tier</label>
          <select id="accom">
            <option value="budget">Budget — Hostel / OYO (₹600/night)</option>
            <option value="mid" selected>Mid-Range — 3★ Hotel (₹2,000/night)</option>
            <option value="luxury">Luxury — 5★ Hotel (₹6,000/night)</option>
          </select>
        </div>

        <div class="hr"></div>

        <div class="field">
          <label class="flabel">Cuisine Preference</label>
          <div class="pills" id="cpills">
            <button class="pill on" data-v="Any">Any</button>
            <button class="pill" data-v="North Indian">North Indian</button>
            <button class="pill" data-v="South Indian">South Indian</button>
            <button class="pill" data-v="Seafood">Seafood</button>
            <button class="pill" data-v="Continental">Continental</button>
            <button class="pill" data-v="Street Food">Street Food</button>
            <button class="pill" data-v="Mughlai">Mughlai</button>
          </div>
        </div>

        <button class="btn-gen" onclick="generate()">Generate Itinerary →</button>

        <div class="saved-wrap">
          <div class="hr"></div>
          <span class="saved-hd">Saved Trips</span>
          <div id="saved-list"></div>
        </div>

      </div>
    </div>
  </aside>

  <!-- OUTPUT -->
  <div id="output">
    <div class="stats-strip anim d1" id="stats"></div>
    <div class="route-card anim d2">
      <div class="s-eyebrow">Route Overview</div>
      <div class="route-track" id="rtrack"></div>
    </div>
    <div class="main-card anim d3">
      <div class="tabs">
        <div class="tab on" onclick="switchTab('itin',this)">Itinerary</div>
        <div class="tab" onclick="switchTab('budget',this)">Budget</div>
        <div class="tab" onclick="switchTab('restaurants',this)">Restaurants</div>
        <div class="tab" onclick="switchTab('hotels',this)">Hotels</div>
      </div>
      <div class="pane on" id="pane-itin"></div>
      <div class="pane" id="pane-budget"></div>
      <div class="pane" id="pane-restaurants"></div>
      <div class="pane" id="pane-hotels"></div>
    </div>
    <div class="act-row anim d4">
